{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "react",
      "react-native",
      "nativewind/types"
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ketobab/shared/*": [
        "../shared/src/*"
      ]
    }
  },
  "include": [
    "app/**/*"
  ],
  "extends": "expo/tsconfig.base"
}
