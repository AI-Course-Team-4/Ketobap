{
  "expo": {
    "name": "KetoBab",
    "slug": "ketobab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ketobab.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ketobab.app"
    },
    "plugins": [],
    "scheme": "ketobab",
    "extra": { "router": { "origin": false } },
    "platforms": ["ios", "android", "web"]
  }
}
